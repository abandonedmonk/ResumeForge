# Copy this file to `.env` and fill in at least one provider key.
# ResumeForge cascades across providers, so any subset works.

# === REQUIRED (at least one) ===
GROQ_API_KEY=           # https://console.groq.com — primary free provider
GOOGLE_API_KEY=         # https://aistudio.google.com/apikey — semantic ATS scoring

# === OPTIONAL FREE FALLBACKS ===
OPENROUTER_API_KEY=     # https://openrouter.ai/keys — free model access
COHERE_API_KEY=         # https://dashboard.cohere.com/api-keys
GITHUB_TOKEN=           # https://github.com/settings/tokens — GitHub Models (Copilot)

# Tip: add numbered keys to rotate across multiple free accounts and dodge rate limits:
# GROQ_API_KEY_1=  GROQ_API_KEY_2=  OPENROUTER_API_KEY_1=  ...

# === PREMIUM (optional, model_tier: premium) ===
OPENAI_API_KEY=         # https://platform.openai.com/api-keys — GPT
ANTHROPIC_API_KEY=      # https://console.anthropic.com/settings/keys — Claude

# === MORE PROVIDERS (optional, OpenAI-compatible; point a stage/chain at them) ===
MISTRAL_API_KEY=        # https://console.mistral.ai/api-keys — Mistral
DEEPSEEK_API_KEY=       # https://platform.deepseek.com/api_keys — DeepSeek
TOGETHER_API_KEY=       # https://api.together.ai/settings/api-keys — Together AI
XAI_API_KEY=            # https://console.x.ai — xAI Grok

# === LOCAL MODELS via Ollama (no key, runs offline) ===
# Uncomment to enable. Requires Ollama running (https://ollama.com) and the model
# pulled: `ollama pull llama3.1`. Then set stage1_model/stage2_model: "ollama" in
# config.yaml (or config.local.yaml). Setting OLLAMA_BASE_URL is what turns it on.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# === GitHub Profile Builder (optional) ===
# NOT an LLM key. Lifts the GitHub API limit from 60/hr (anon) to 5000/hr for
# importing repo READMEs. Kept separate from GITHUB_TOKEN (which is the Copilot
# LLM provider). A fine-grained read-only token is enough.
GITHUB_API_TOKEN=       # https://github.com/settings/tokens
